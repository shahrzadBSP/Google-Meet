<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>آموزش Google Meet | بانیان صنعت پرشین</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Vazirmatn:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
/* ===== RESET & BASE ===== */
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;font-size:16px}
body{
  font-family:'Vazirmatn',sans-serif;
  color:#e8f0fe;
  min-height:100vh;
  overflow-x:hidden;
  background:#0d1b3e;
}

/* ===== MESH GRADIENT BACKGROUND ===== */
.mesh-bg{
  position:fixed;inset:0;z-index:0;
  background:
    radial-gradient(ellipse 70% 60% at 10% 10%, rgba(26,82,160,0.75) 0%,transparent 55%),
    radial-gradient(ellipse 55% 70% at 90% 15%, rgba(15,55,120,0.70) 0%,transparent 50%),
    radial-gradient(ellipse 60% 50% at 50% 90%, rgba(230,100,20,0.28) 0%,transparent 55%),
    radial-gradient(ellipse 80% 40% at 80% 60%, rgba(10,40,100,0.65) 0%,transparent 60%),
    radial-gradient(ellipse 40% 60% at 20% 75%, rgba(20,60,140,0.50) 0%,transparent 55%),
    radial-gradient(ellipse 100% 100% at 50% 50%, rgba(8,30,80,0.90) 0%,transparent 100%),
    linear-gradient(145deg, #0d1b3e 0%, #0a1530 40%, #071228 100%);
  pointer-events:none;
}
.mesh-bg::after{
  content:'';position:absolute;inset:0;
  background:
    radial-gradient(circle 600px at 30% 40%, rgba(255,120,30,0.06) 0%,transparent 60%),
    radial-gradient(circle 400px at 70% 70%, rgba(30,100,220,0.10) 0%,transparent 60%);
  pointer-events:none;
}

/* ===== PROGRESS BAR ===== */
#readingBar{
  position:fixed;top:0;left:0;right:0;height:4px;z-index:9999;
  background:rgba(255,255,255,0.08);
}
#readingFill{
  height:100%;width:0%;
  background:linear-gradient(90deg,#e66a1a,#ff9f50);
  border-radius:0 4px 4px 0;
  transition:width .2s ease;
  box-shadow:0 0 12px rgba(255,120,30,0.6);
}

/* ===== FLOATING NAV ===== */
#floatNav{
  position:fixed;right:1.2rem;top:50%;transform:translateY(-50%);z-index:500;
  display:flex;flex-direction:column;gap:.5rem;
  background:rgba(255,255,255,0.06);
  border:1px solid rgba(255,255,255,0.12);
  border-radius:50px;padding:.6rem .5rem;
  backdrop-filter:blur(20px);
  box-shadow:0 8px 32px rgba(0,0,0,0.4);
}
.nav-dot{
  width:10px;height:10px;border-radius:50%;
  background:rgba(255,255,255,0.25);
  cursor:pointer;border:none;
  transition:all .25s;position:relative;
  outline:none;
}
.nav-dot:hover,.nav-dot.active{
  background:#e66a1a;
  box-shadow:0 0 10px rgba(230,106,26,.7);
  transform:scale(1.35);
}
.nav-dot::after{
  content:attr(data-label);
  position:absolute;right:calc(100% + 10px);top:50%;transform:translateY(-50%);
  background:rgba(10,25,65,0.92);color:#e8f0fe;
  font-size:.72rem;white-space:nowrap;padding:4px 10px;border-radius:6px;
  opacity:0;pointer-events:none;transition:opacity .2s;
  font-family:'Vazirmatn',sans-serif;
  border:1px solid rgba(255,255,255,0.1);
}
.nav-dot:hover::after{opacity:1}

/* ===== BACK TO TOP ===== */
#backTop{
  position:fixed;left:1.2rem;bottom:1.5rem;z-index:500;
  width:44px;height:44px;border-radius:50%;border:none;
  background:linear-gradient(135deg,#1a4fa0,#e66a1a);
  color:#fff;font-size:1.1rem;cursor:pointer;
  box-shadow:0 6px 24px rgba(0,0,0,0.4);
  transition:all .25s;opacity:0;transform:scale(0.8);
}
#backTop.show{opacity:1;transform:scale(1)}
#backTop:hover{transform:scale(1.12)}

/* ===== GLASSMORPHISM CARD ===== */
.glass{
  background:rgba(255,255,255,0.07);
  border:1px solid rgba(255,255,255,0.14);
  border-radius:22px;
  backdrop-filter:blur(22px) saturate(1.5);
  -webkit-backdrop-filter:blur(22px);
  box-shadow:
    0 8px 32px rgba(0,0,0,0.35),
    0 2px 8px rgba(0,0,0,0.2),
    inset 0 1px 0 rgba(255,255,255,0.12);
  transition:transform .3s cubic-bezier(.34,1.4,.64,1), box-shadow .3s ease;
}
.glass:hover{
  transform:translateY(-5px) scale(1.012);
  box-shadow:
    0 20px 60px rgba(0,0,0,0.45),
    0 4px 16px rgba(0,0,0,0.25),
    inset 0 1px 0 rgba(255,255,255,0.15);
}
.glass-sm{
  background:rgba(255,255,255,0.06);
  border:1px solid rgba(255,255,255,0.11);
  border-radius:16px;
  backdrop-filter:blur(18px);
  box-shadow:0 4px 20px rgba(0,0,0,0.28),inset 0 1px 0 rgba(255,255,255,0.08);
  transition:transform .25s cubic-bezier(.34,1.4,.64,1),box-shadow .25s;
}
.glass-sm:hover{transform:translateY(-3px);box-shadow:0 10px 36px rgba(0,0,0,0.38)}

/* ===== ACCENT ===== */
.accent{color:#ff8c42}
.accent-bg{background:linear-gradient(135deg,#e66a1a,#ff9f50)}
.blue-accent{color:#6ab0ff}

/* ===== SCROLL ANIMATIONS ===== */
.reveal{
  opacity:0;transform:translateY(30px);
  transition:opacity .65s ease, transform .65s cubic-bezier(.34,1.2,.64,1);
}
.reveal.vis{opacity:1;transform:none}
.reveal-l{opacity:0;transform:translateX(-30px);transition:opacity .6s ease,transform .6s cubic-bezier(.34,1.2,.64,1)}
.reveal-l.vis{opacity:1;transform:none}
.reveal-r{opacity:0;transform:translateX(30px);transition:opacity .6s ease,transform .6s cubic-bezier(.34,1.2,.64,1)}
.reveal-r.vis{opacity:1;transform:none}

/* ===== WRAPPER ===== */
.wrapper{position:relative;z-index:1}
.container{max-width:1100px;margin:0 auto;padding:0 1.2rem}

/* ===== HEADER ===== */
header{
  position:sticky;top:0;z-index:400;
  background:rgba(8,20,55,0.75);
  border-bottom:1px solid rgba(255,255,255,0.1);
  backdrop-filter:blur(24px);
  padding:.75rem 0;
}
.header-inner{display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap}
.logo-area{display:flex;align-items:center;gap:.9rem}
.logo-img{height:48px;width:auto;border-radius:8px}
.brand-name{font-size:1rem;font-weight:700;color:#e8f0fe;line-height:1.3}
.brand-sub{font-size:.72rem;color:#94b8e8;font-weight:400}
.header-badge{
  background:rgba(230,106,26,.18);border:1px solid rgba(230,106,26,.35);
  border-radius:100px;padding:.35rem 1rem;font-size:.78rem;color:#ff9f50;font-weight:500;
}

/* ===== HERO ===== */
.hero{padding:4.5rem 0 3rem;text-align:center}
.hero-tag{
  display:inline-flex;align-items:center;gap:.5rem;
  background:rgba(230,106,26,.15);border:1px solid rgba(230,106,26,.3);
  border-radius:100px;padding:.4rem 1.2rem;font-size:.82rem;color:#ff8c42;
  margin-bottom:1.2rem;
}
.hero h1{font-size:clamp(1.8rem,4vw,3rem);font-weight:800;line-height:1.25;margin-bottom:1rem;color:#fff}
.hero h1 span{
  background:linear-gradient(135deg,#6ab0ff,#ff8c42);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.hero-desc{font-size:1.05rem;color:#94b8e8;max-width:640px;margin:0 auto 2rem;line-height:1.9}
.hero-stats{display:flex;gap:1.2rem;justify-content:center;flex-wrap:wrap;margin-bottom:2.2rem}
.stat-chip{
  display:flex;align-items:center;gap:.5rem;
  background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);
  border-radius:100px;padding:.45rem 1.1rem;font-size:.85rem;color:#c5d8f5;
}
.stat-chip i{color:#ff8c42}
.btn-start{
  background:linear-gradient(135deg,#e66a1a,#ff9f50);
  color:#fff;border:none;border-radius:16px;
  padding:1rem 2.8rem;font-size:1.05rem;font-family:'Vazirmatn',sans-serif;
  font-weight:700;cursor:pointer;letter-spacing:.02em;
  box-shadow:0 8px 28px rgba(230,106,26,0.45);
  transition:all .25s;
}
.btn-start:hover{transform:translateY(-3px);box-shadow:0 14px 40px rgba(230,106,26,0.55)}
.btn-start:active{transform:scale(.97)}

/* ===== SECTION ===== */
section{padding:3.5rem 0;scroll-margin-top:80px}
.sec-header{margin-bottom:2rem}
.sec-num{
  display:inline-flex;align-items:center;justify-content:center;
  width:36px;height:36px;border-radius:10px;
  background:linear-gradient(135deg,#e66a1a,#ff9f50);
  color:#fff;font-size:.9rem;font-weight:800;margin-bottom:.6rem;
  box-shadow:0 4px 16px rgba(230,106,26,0.4);
}
.sec-header h2{font-size:1.55rem;font-weight:700;color:#fff;margin-bottom:.4rem}
.sec-header p{font-size:.92rem;color:#7fa8d8;line-height:1.8}
.divider{width:60px;height:3px;background:linear-gradient(90deg,#e66a1a,transparent);border-radius:10px;margin:.6rem 0}

/* ===== BENTO GRID ===== */
.bento{display:grid;gap:1.1rem}
.bento-3{grid-template-columns:repeat(3,1fr)}
.bento-2{grid-template-columns:repeat(2,1fr)}
.bento-auto{grid-template-columns:repeat(auto-fit,minmax(220px,1fr))}
.span2{grid-column:span 2}
.span3{grid-column:span 3}
.bento-card{padding:1.5rem}
.bento-card.tall{min-height:200px}

/* ===== SECTION 1 — INTRO ===== */
.intro-main{padding:2rem;display:flex;flex-direction:column;gap:1rem}
.intro-logo-meet{font-size:3.5rem;margin-bottom:.3rem}
.intro-title{font-size:1.15rem;font-weight:700;color:#fff;margin-bottom:.5rem}
.intro-body{font-size:.88rem;color:#94b8e8;line-height:1.85}
.badge-row{display:flex;gap:.5rem;flex-wrap:wrap;margin-top:.5rem}
.badge{
  display:inline-block;border-radius:100px;padding:3px 12px;
  font-size:.75rem;font-weight:600;
}
.badge-blue{background:rgba(106,176,255,.15);color:#6ab0ff;border:1px solid rgba(106,176,255,.25)}
.badge-orange{background:rgba(230,106,26,.18);color:#ff9f50;border:1px solid rgba(230,106,26,.3)}
.benefit-item{display:flex;align-items:flex-start;gap:.7rem;margin-bottom:.7rem}
.benefit-icon{
  width:34px;height:34px;border-radius:10px;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;font-size:.95rem;
  background:rgba(230,106,26,.18);color:#ff8c42;
  border:1px solid rgba(230,106,26,.25);
}
.benefit-text strong{display:block;font-size:.88rem;font-weight:600;color:#e8f0fe;margin-bottom:2px}
.benefit-text span{font-size:.8rem;color:#7fa8d8}

/* ===== SECTION 2 — JOIN ===== */
.step-card{padding:1.4rem;text-align:center}
.step-icon{
  width:56px;height:56px;border-radius:16px;
  background:linear-gradient(135deg,rgba(26,79,160,0.7),rgba(10,30,80,0.7));
  border:1px solid rgba(106,176,255,0.25);
  display:flex;align-items:center;justify-content:center;
  font-size:1.5rem;margin:0 auto .8rem;
  box-shadow:0 4px 20px rgba(26,79,160,0.35);
}
.step-card h4{font-size:.95rem;font-weight:600;color:#fff;margin-bottom:.4rem}
.step-card p{font-size:.82rem;color:#7fa8d8;line-height:1.75}
.step-num{
  display:inline-flex;align-items:center;justify-content:center;
  width:24px;height:24px;border-radius:50%;
  background:linear-gradient(135deg,#e66a1a,#ff9f50);
  color:#fff;font-size:.72rem;font-weight:800;margin-bottom:.6rem;
}
.screenshot{
  width:100%;border-radius:14px;margin-top:12px;
  border:1px solid rgba(255,255,255,0.12);
  transition:transform .2s;
}
.screenshot:hover{transform:scale(1.02)}

/* ===== SECTION 3 — FEATURES ===== */
.feat-card{padding:1.3rem;display:flex;flex-direction:column;align-items:flex-start;gap:.6rem}
.feat-icon{
  width:44px;height:44px;border-radius:12px;
  display:flex;align-items:center;justify-content:center;font-size:1.2rem;
  transition:transform .25s;flex-shrink:0;
}
.feat-card:hover .feat-icon{transform:scale(1.12) rotate(-4deg)}
.fi-mic{background:rgba(230,106,26,.2);color:#ff9f50;border:1px solid rgba(230,106,26,.3)}
.fi-cam{background:rgba(26,100,200,.25);color:#6ab0ff;border:1px solid rgba(26,100,200,.3)}
.fi-share{background:rgba(34,197,94,.18);color:#4ade80;border:1px solid rgba(34,197,94,.25)}
.fi-chat{background:rgba(168,85,247,.2);color:#c084fc;border:1px solid rgba(168,85,247,.28)}
.fi-bg{background:rgba(251,191,36,.15);color:#fbbf24;border:1px solid rgba(251,191,36,.25)}
.fi-ppl{background:rgba(20,184,166,.18);color:#2dd4bf;border:1px solid rgba(20,184,166,.28)}
.fi-rec{background:rgba(239,68,68,.18);color:#f87171;border:1px solid rgba(239,68,68,.28)}
.feat-card h4{font-size:.9rem;font-weight:600;color:#e8f0fe;margin:0}
.feat-card p{font-size:.8rem;color:#7fa8d8;line-height:1.75;margin:0}
.feat-kbd{
  display:inline-block;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.18);
  border-radius:6px;padding:2px 8px;font-size:.7rem;color:#c5d8f5;
  font-family:monospace;
}

/* ===== SECTION 4 — TIPS ===== */
.tip-card{padding:1.3rem;display:flex;align-items:flex-start;gap:.9rem}
.tip-num{
  width:36px;height:36px;border-radius:10px;flex-shrink:0;
  background:linear-gradient(135deg,#e66a1a,#ff9f50);
  color:#fff;font-size:.85rem;font-weight:800;
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 4px 14px rgba(230,106,26,0.35);
}
.tip-card h4{font-size:.9rem;font-weight:600;color:#e8f0fe;margin-bottom:.3rem}
.tip-card p{font-size:.8rem;color:#7fa8d8;line-height:1.75}

/* ===== SECTION 5 — PROBLEMS TABLE ===== */
.prob-table{width:100%;border-collapse:collapse;font-size:.88rem}
.prob-table th{
  padding:.9rem 1.2rem;text-align:right;font-weight:600;
  background:rgba(230,106,26,.18);color:#ff9f50;
  font-size:.82rem;letter-spacing:.02em;
}
.prob-table th:first-child{border-radius:0 10px 0 0}
.prob-table th:last-child{border-radius:10px 0 0 0}
.prob-table td{padding:.85rem 1.2rem;border-bottom:1px solid rgba(255,255,255,.07);color:#c5d8f5;line-height:1.75}
.prob-table tr:last-child td{border-bottom:none}
.prob-table tr:hover td{background:rgba(255,255,255,.04)}
.prob-icon{color:#ff8c42;margin-left:.4rem}
.sol-icon{color:#4ade80;margin-left:.4rem}
.prob-wrap{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);border-radius:16px;overflow:hidden}

/* ===== SECTION 6 — SHORTCUTS ===== */
.shortcut-table{width:100%;border-collapse:collapse;font-size:.86rem}
.shortcut-table th{
  padding:.8rem 1.2rem;text-align:right;font-weight:600;
  background:rgba(26,79,160,.35);color:#6ab0ff;font-size:.8rem;
}
.shortcut-table th:first-child{border-radius:0 10px 0 0}
.shortcut-table th:last-child{border-radius:10px 0 0 0}
.shortcut-table td{padding:.75rem 1.2rem;border-bottom:1px solid rgba(255,255,255,.06);color:#c5d8f5;vertical-align:middle}
.shortcut-table tr:last-child td{border-bottom:none}
.shortcut-table tr:hover td{background:rgba(255,255,255,.04)}
.key-wrap{display:flex;gap:4px;flex-direction:row-reverse;flex-wrap:wrap}
.key{
  display:inline-flex;align-items:center;justify-content:center;
  background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.22);
  border-bottom:3px solid rgba(255,255,255,.18);
  border-radius:7px;padding:3px 10px;font-size:.75rem;
  color:#e8f0fe;font-family:monospace;font-weight:600;min-width:32px;
}
.os-tag{font-size:.68rem;color:#94b8e8;margin-left:4px}
.sc-wrap{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);border-radius:16px;overflow:hidden}

/* ===== SECTION 7 — CHECKLIST ===== */
.checklist{display:grid;gap:.7rem}
.cl-item{
  display:flex;align-items:center;gap:.9rem;
  background:rgba(255,255,255,.055);border:1px solid rgba(255,255,255,.1);
  border-radius:14px;padding:1rem 1.2rem;cursor:pointer;
  transition:all .25s cubic-bezier(.34,1.4,.64,1);
  user-select:none;
}
.cl-item:hover{background:rgba(255,255,255,.09);transform:translateX(-4px)}
.cl-item.checked{
  background:rgba(34,197,94,.1);border-color:rgba(34,197,94,.3);
  transform:none;
}
.cl-item.checked .cl-label{color:#86efac;text-decoration:line-through;opacity:.7}
.cl-box{
  width:26px;height:26px;border-radius:8px;flex-shrink:0;
  border:2px solid rgba(255,255,255,.25);
  display:flex;align-items:center;justify-content:center;
  transition:all .25s;background:transparent;
}
.cl-item.checked .cl-box{
  background:linear-gradient(135deg,#22c55e,#4ade80);border-color:transparent;
  box-shadow:0 4px 14px rgba(34,197,94,.35);
}
.cl-box i{font-size:.75rem;color:#fff;opacity:0;transition:opacity .2s}
.cl-item.checked .cl-box i{opacity:1}
.cl-label{font-size:.9rem;color:#c5d8f5;font-weight:500;transition:all .25s}
.cl-progress-wrap{
  margin-top:1.2rem;display:flex;align-items:center;gap:.8rem;
}
.cl-progress-bar{flex:1;height:8px;border-radius:100px;background:rgba(255,255,255,.1)}
.cl-progress-fill{height:100%;border-radius:100px;background:linear-gradient(90deg,#22c55e,#4ade80);transition:width .4s ease}
.cl-pct{font-size:.82rem;font-weight:700;color:#4ade80;min-width:36px;text-align:left}
#clDone{
  display:none;margin-top:1.2rem;padding:1rem 1.5rem;
  background:rgba(34,197,94,.12);border:1px solid rgba(34,197,94,.3);
  border-radius:16px;text-align:center;color:#86efac;font-size:.95rem;font-weight:600;
  animation:popIn .4s cubic-bezier(.34,1.56,.64,1);
}
@keyframes popIn{from{transform:scale(.8);opacity:0}to{transform:scale(1);opacity:1}}

/* ===== SUMMARY ===== */
#summary{padding:3.5rem 0 4rem}
.summary-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:.9rem}
.sum-card{
  padding:1.2rem;text-align:center;
  background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.11);
  border-radius:18px;
  transition:transform .25s cubic-bezier(.34,1.4,.64,1),box-shadow .25s;
}
.sum-card:hover{transform:translateY(-5px);box-shadow:0 14px 40px rgba(0,0,0,.4)}
.sum-icon{font-size:2rem;margin-bottom:.5rem}
.sum-card h4{font-size:.85rem;font-weight:600;color:#e8f0fe;margin-bottom:.3rem}
.sum-card p{font-size:.78rem;color:#7fa8d8;line-height:1.6}

/* ===== FOOTER ===== */
footer{
  background:rgba(5,12,35,0.75);border-top:1px solid rgba(255,255,255,.08);
  padding:1.5rem 0;text-align:center;
  backdrop-filter:blur(20px);
}
footer p{font-size:.8rem;color:#4a6fa8}
footer span{color:#ff8c42}

/* ===== FAQ ACCORDION ===== */
.faq-item{
  background:rgba(255,255,255,.055);border:1px solid rgba(255,255,255,.1);
  border-radius:14px;overflow:hidden;margin-bottom:.7rem;
  transition:box-shadow .2s;
}
.faq-item:hover{box-shadow:0 6px 24px rgba(0,0,0,.28)}
.faq-q{
  display:flex;align-items:center;justify-content:space-between;
  padding:1rem 1.3rem;cursor:pointer;font-size:.9rem;font-weight:600;color:#e8f0fe;
  gap:1rem;
}
.faq-q i{color:#ff8c42;transition:transform .3s;flex-shrink:0}
.faq-item.open .faq-q i{transform:rotate(180deg)}
.faq-a{
  max-height:0;overflow:hidden;
  transition:max-height .35s cubic-bezier(.4,0,.2,1),padding .3s;
  font-size:.85rem;color:#94b8e8;line-height:1.85;
  padding:0 1.3rem;
}
.faq-item.open .faq-a{max-height:200px;padding:.5rem 1.3rem 1.2rem}

/* ===== RESPONSIVE ===== */
@media(max-width:768px){
  .bento-3{grid-template-columns:1fr}
  .bento-2{grid-template-columns:1fr}
  .span2,.span3{grid-column:span 1}
  #floatNav{display:none}
  .header-badge{display:none}
  .hero h1{font-size:1.7rem}
}
@media(max-width:580px){
  .hero-stats{gap:.6rem}
  .stat-chip{font-size:.75rem;padding:.35rem .8rem}
}
</style>
</head>
<body>

