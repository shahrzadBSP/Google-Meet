<script>
window.addEventListener('scroll', () => {
  const total = document.documentElement.scrollHeight - window.innerHeight;
  const pct = (window.scrollY / total) * 100;
  document.getElementById('readingFill').style.width = pct + '%';
  const bt = document.getElementById('backTop');
  bt.classList.toggle('show', window.scrollY > 400);
  const sections = ['hero','s1','s2','s3','s4','s5','s6','s7','summary'];
  let current = sections[0];
  sections.forEach(id => {
    const el = document.getElementById(id);
    if (el && el.getBoundingClientRect().top <= 120) current = id;
  });
  document.querySelectorAll('.nav-dot').forEach(dot => {
    dot.classList.toggle('active', dot.dataset.section === current);
  });
});
function scrollTo(id) { document.querySelector(id)?.scrollIntoView({ behavior: 'smooth' }); }
const observer = new IntersectionObserver((entries) => {
  entries.forEach((e, i) => { if (e.isIntersecting) setTimeout(() => e.target.classList.add('vis'), e.target.dataset.delay || 0); });
}, { threshold: 0.12 });
document.querySelectorAll('.reveal,.reveal-l,.reveal-r').forEach((el, i) => {
  el.dataset.delay = (i % 4) * 80;
  observer.observe(el);
});
function toggleFaq(el) {
  const item = el.closest('.faq-item');
  const wasOpen = item.classList.contains('open');
  document.querySelectorAll('.faq-item').forEach(f => f.classList.remove('open'));
  if (!wasOpen) item.classList.add('open');
}
function toggleCheck(item) {
  item.classList.toggle('checked');
  updateProgress();
}
function updateProgress() {
  const items = document.querySelectorAll('.cl-item');
  const checked = document.querySelectorAll('.cl-item.checked').length;
  const pct = Math.round((checked / items.length) * 100);
  document.getElementById('clFill').style.width = pct + '%';
  document.getElementById('clPct').textContent = pct + '%';
  const done = document.getElementById('clDone');
  done.style.display = pct === 100 ? 'block' : 'none';
}
</script>
